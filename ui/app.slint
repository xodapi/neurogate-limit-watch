import { Button, ComboBox, CheckBox } from "std-widgets.slint";
import { Theme } from "theme.slint";

component MeterBar inherits Rectangle {
    in property <float> value;
    in property <brush> fill;
    private property <float> clipped: root.value < 0 ? 0 : root.value > 100 ? 100 : root.value;

    height: 12px;
    background: Theme.border;
    border-radius: 6px;

    Rectangle {
        width: max(0px, parent.width * root.clipped / 100);
        height: parent.height;
        border-radius: 6px;
        background: root.fill;
    }
}

component LimitCard inherits Rectangle {
    in property <string> name;
    in property <string> level;
    in property <string> reset;
    in property <string> credits;
    in property <string> requests;
    in property <string> rate;
    in property <string> percent-text;
    in property <float> percent;
    in property <float> credit-percent;
    in property <float> request-percent;
    in property <[float]> trend-data;
    in property <bool> stealth-mode;

    in property <bool> dimmed: false;
    visible: root.level != "unknown";

    private property <brush> accent: root.percent >= 90 ? Theme.danger : root.percent >= 75 ? Theme.warning : Theme.success;

    opacity: root.dimmed ? 0.36 : 1.0;
    background: Theme.bg-card;
    border-color: root.dimmed ? Theme.border : Theme.border;
    border-width: 1px;
    border-radius: 8px;
    min-height: 195px;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        HorizontalLayout {
            padding-bottom: 2px;
            Text {
                text: root.name;
                color: Theme.text-primary;
                font-size: 25px;
                font-weight: 700;
            }

            Rectangle { }

            Rectangle {
                width: 92px;
                height: 28px;
                border-radius: 14px;
                background: root.accent;

                Text {
                    text: root.level;
                    color: #11141a;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        MeterBar {
            value: root.percent;
            fill: root.accent;
        }

        if (root.trend-data.length > 0) : HorizontalLayout {
            height: 20px;
            spacing: 2px;
            alignment: center;
            for val in root.trend-data : Rectangle {
                background: val >= 90 ? #d66f73 : val >= 75 ? #caa45f : #78ad84;
                opacity: 0.6;
                width: 4px;
                height: max(2px, parent.height * val / 100);
                y: parent.height - self.height;
                border-radius: 1px;
            }
        }

        Text {
            text: root.percent-text;
            color: root.accent;
            font-size: 44px;
            font-weight: 800;
        }

        Rectangle {
            height: 34px;
            background: #111721;
            border-radius: 6px;

            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 4px;

                HorizontalLayout {
                    spacing: 8px;

                    Text {
                        width: 58px;
                        text: "кред";
                        color: Theme.text-muted;
                        font-size: 11px;
                    }

                    MeterBar {
                        value: root.credit-percent;
                        fill: #78ad84;
                    }
                }

                HorizontalLayout {
                    spacing: 8px;

                    Text {
                        width: 58px;
                        text: "запросы";
                        color: Theme.text-muted;
                        font-size: 11px;
                    }

                    MeterBar {
                        value: root.request-percent;
                        fill: #7f9fc8;
                    }
                }
            }
        }

        Text {
            text: root.stealth-mode ? "кредиты: ***" : root.credits;
            color: Theme.text-muted;
            font-size: 12px;
        }

        Text {
            text: root.stealth-mode ? "запросы: ***" : root.requests;
            color: Theme.text-muted;
            font-size: 12px;
        }

        Text {
            text: root.rate;
            color: Theme.text-muted;
            font-size: 11px;
        }

        Text {
            text: root.reset;
            color: Theme.text-muted;
            font-size: 11px;
        }
    }
}

export component AppWindow inherits Window {
    title: "vimit-gui";
    in-out property <bool> is-overlay: false;
    in-out property <bool> is-compact: false;
    in property <float> token-rate-raw: 0.0;

    preferred-width: root.is-overlay ? (root.is-compact ? 220px : 300px) : 1120px;
    preferred-height: root.is-overlay ? (root.is-compact ? 40px : 340px) : 680px;
    min-width: root.is-overlay ? (root.is-compact ? 220px : 300px) : 860px;
    min-height: root.is-overlay ? (root.is-compact ? 40px : 340px) : 620px;
    no-frame: root.is-overlay;
    always-on-top: root.is-overlay;
    background: root.is-overlay ? transparent : Theme.bg-primary;


    callback refresh-requested();
    callback demo-requested();
    callback settings-changed(float, float);
    callback account-changed(string);
    callback check-updates();
    callback auto-update-changed(bool);
    callback close-overlay();
    callback open-config-dir();
    in-out property <string> error-text: "";
    in-out property <bool> needs-setup: false;

    in-out property <[string]> account-names: [];
    in-out property <string> current-account: "";

    in property <[float]> five-trend-data: [];
    in property <[float]> day-trend-data: [];
    in property <[float]> week-trend-data: [];
    in property <[float]> month-trend-data: [];
    in-out property <bool> stealth-mode: false;
    in property <string> active-endpoint-label: "";
    in property <int> api-offline-min: -1;
    in property <string> new-version-label: "";
    in-out property <bool> auto-update-check: true;

    in property <string> status-text: "Запуск...";
    in property <string> source-text: "источник: загрузка";
    in property <string> agent-text: "агенты: нет данных";
    in property <string> token-rate-text: "токены/мин: нет данных";
    in property <string> footer-text: ".env: текущая папка, затем рядом с exe";
    in-out property <bool> settings-open: false;
    in-out property <int> period-mode: 0;
    in-out property <bool> risk-only: false;

    in-out property <float> warning-threshold: 75.0;
    in-out property <float> danger-threshold: 90.0;
    in-out property <int> refresh-interval: 10;

    in property <string> five-level: "загрузка";
    in property <string> five-reset: "сброс неизвестен";
    in property <string> five-credits: "кредиты: н/д";
    in property <string> five-requests: "запросы: н/д";
    in property <string> five-rate: "темп окна: н/д";
    in property <string> five-percent-text: "0,0%";
    in property <float> five-percent: 0;
    in property <float> five-credit-percent: 0;
    in property <float> five-request-percent: 0;

    in property <string> day-level: "загрузка";
    in property <string> day-reset: "сброс неизвестен";
    in property <string> day-credits: "кредиты: н/д";
    in property <string> day-requests: "запросы: н/д";
    in property <string> day-rate: "темп окна: н/д";
    in property <string> day-percent-text: "0,0%";
    in property <float> day-percent: 0;
    in property <float> day-credit-percent: 0;
    in property <float> day-request-percent: 0;

    in property <string> week-level: "загрузка";
    in property <string> week-reset: "сброс неизвестен";
    in property <string> week-credits: "кредиты: н/д";
    in property <string> week-requests: "запросы: н/д";
    in property <string> week-rate: "темп окна: н/д";
    in property <string> week-percent-text: "0,0%";
    in property <float> week-percent: 0;
    in property <float> week-credit-percent: 0;
    in property <float> week-request-percent: 0;

    in property <string> month-level: "загрузка";
    in property <string> month-reset: "сброс неизвестен";
    in property <string> month-credits: "кредиты: н/д";
    in property <string> month-requests: "запросы: н/д";
    in property <string> month-rate: "темп окна: н/д";
    in property <string> month-percent-text: "0,0%";
    in property <float> month-percent: 0;
    in property <float> month-credit-percent: 0;
    in property <float> month-request-percent: 0;

    if (!root.is-overlay && !root.needs-setup) : Rectangle {
        background: Theme.bg-primary;

        VerticalLayout {
            padding: 18px;
            spacing: 12px;

            if (root.error-text != "") : Rectangle {
                height: 32px;
                background: #d66f73;
                border-radius: 8px;

                Text {
                    text: root.error-text;
                    color: #ffffff;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if (root.api-offline-min >= 0) : Rectangle {
                height: 32px;
                background: Theme.danger;
                border-radius: 8px;

                Text {
                    text: "VibeMode недоступен · уже " + root.api-offline-min + " мин";
                    color: #ffffff;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                min-height: 245px;
                background: Theme.bg-card;
                border-radius: 10px;
                border-color: Theme.border;
                border-width: 1px;

                HorizontalLayout {
                    padding: 16px;
                    spacing: 24px;

                    VerticalLayout {
                        spacing: 10px;

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;
                            Text {
                                text: "VibeMode Control";
                                color: Theme.text-primary;
                                font-size: 28px;
                                font-weight: 800;
                            }
                            if (root.active-endpoint-label != "") : Rectangle {
                                width: 72px;
                                height: 22px;
                                y: 6px;
                                border-radius: 11px;
                                background: root.active-endpoint-label == "api" ? #caa45f : #78ad84;
                                Text {
                                    text: root.active-endpoint-label;
                                    color: #11141a;
                                    font-size: 11px;
                                    font-weight: 800;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            if (root.new-version-label != "") : Rectangle {
                                width: 140px;
                                height: 22px;
                                y: 6px;
                                border-radius: 11px;
                                background: #d66f73; // light red/orange alert color
                                Text {
                                    text: "Обновление: v" + root.new-version-label;
                                    color: #ffffff;
                                    font-size: 11px;
                                    font-weight: 800;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Text {
                            text: root.status-text;
                            color: Theme.text-muted;
                            font-size: 15px;
                        }

                        Rectangle {
                            height: 1px;
                            background: #2c3549;
                        }

                        Text {
                            text: root.source-text;
                            color: #7fb69c;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        Text {
                            text: root.agent-text;
                            color: #8da6c8;
                            font-size: 14px;
                        }

                        Text {
                            text: root.token-rate-text;
                            color: #c8b56b;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            height: 34px;

                            Button {
                                text: "Обновить";
                                clicked => { root.refresh-requested(); }
                            }

                            Button {
                                text: "Демо";
                                clicked => { root.demo-requested(); }
                            }

                            Button {
                                text: root.settings-open ? "Скрыть настройки" : "Настройки";
                                clicked => { root.settings-open = !root.settings-open; }
                            }

                            Rectangle { }
                        }
                    }

                    Rectangle { }
                }
            }

            Rectangle {
                visible: root.settings-open;
                height: root.settings-open ? 230px : 0px;
                background: Theme.bg-card;
                border-radius: 8px;
                border-color: Theme.border;
                border-width: 1px;
                clip: true;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 20px;

                        VerticalLayout {
                            width: 220px;
                            spacing: 4px;

                            Text {
                                text: "Настройки панели";
                                color: Theme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            Text {
                                text: "фильтры без чтения приватных данных";
                                color: Theme.text-muted;
                                font-size: 11px;
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;

                            Button {
                                text: "Все";
                                clicked => {
                                    root.period-mode = 0;
                                    root.risk-only = false;
                                }
                            }

                            Button {
                                text: "5h + 24h";
                                clicked => {
                                    root.period-mode = 1;
                                    root.risk-only = false;
                                }
                            }

                            Button {
                                text: "7d + 30d";
                                clicked => {
                                    root.period-mode = 2;
                                    root.risk-only = false;
                                }
                            }

                            Button {
                                text: root.stealth-mode ? "🔓 Показать" : "🔒 Скрыть";
                                clicked => {
                                    root.stealth-mode = !root.stealth-mode;
                                }
                            }

                            Button {
                                text: "Только риск";
                                clicked => {
                                    root.period-mode = 0;
                                    root.risk-only = !root.risk-only;
                                }
                            }
                            CheckBox {
                                text: "Светлая тема";
                                checked: !Theme.dark-mode;
                                toggled => { Theme.dark-mode = !self.checked; }
                            }
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: #2c3549;
                    }

                    HorizontalLayout {
                        spacing: 20px;

                        VerticalLayout {
                            width: 220px;
                            spacing: 4px;

                            Text {
                                text: "Аккаунт";
                                color: Theme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            Text {
                                text: "выбор профиля для лимитов";
                                color: Theme.text-muted;
                                font-size: 11px;
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;
                            visible: root.account-names.length > 0;

                            Text {
                                text: "account";
                                color: #caa45f;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            ComboBox {
                                model: root.account-names;
                                current-value: root.current-account;
                                selected(value) => {
                                    root.current-account = value;
                                    root.account-changed(value);
                                }
                            }

                            Rectangle { }
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: #2c3549;
                    }

                    HorizontalLayout {
                        spacing: 20px;

                        VerticalLayout {
                            width: 220px;
                            spacing: 4px;

                            Text {
                                text: "Пороги";
                                color: Theme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            Text {
                                text: "warning: \{round(root.warning-threshold)}% | danger: \{round(root.danger-threshold)}%";
                                color: Theme.text-muted;
                                font-size: 11px;
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;

                            Text {
                                text: "warning";
                                color: #caa45f;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "\{round(root.warning-threshold)}%";
                                color: Theme.text-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                min-width: 40px;
                            }

                            Button {
                                text: "-";
                                clicked => {
                                    if (root.warning-threshold > 10) {
                                        root.warning-threshold -= 5;
                                        root.settings-changed(root.warning-threshold, root.danger-threshold);
                                    }
                                }
                            }

                            Button {
                                text: "+";
                                clicked => {
                                    if (root.warning-threshold < root.danger-threshold - 5) {
                                        root.warning-threshold += 5;
                                        root.settings-changed(root.warning-threshold, root.danger-threshold);
                                    }
                                }
                            }

                            Rectangle { width: 20px; }

                            Text {
                                text: "danger";
                                color: #d66f73;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "\{round(root.danger-threshold)}%";
                                color: Theme.text-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                min-width: 40px;
                            }

                            Button {
                                text: "-";
                                clicked => {
                                    if (root.danger-threshold > root.warning-threshold + 5) {
                                        root.danger-threshold -= 5;
                                        root.settings-changed(root.warning-threshold, root.danger-threshold);
                                    }
                                }
                            }

                            Button {
                                text: "+";
                                clicked => {
                                    if (root.danger-threshold < 100) {
                                        root.danger-threshold += 5;
                                        root.settings-changed(root.warning-threshold, root.danger-threshold);
                                    }
                                }
                            }

                            Rectangle { }

                            Text {
                                text: root.risk-only ? "режим: риск" : root.period-mode == 1 ? "режим: короткие окна" : root.period-mode == 2 ? "режим: длинные окна" : "режим: все окна";
                                color: #aeb8c7;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: #2c3549;
                    }

                    HorizontalLayout {
                        spacing: 20px;

                        VerticalLayout {
                            width: 220px;
                            spacing: 4px;

                            Text {
                                text: "Обновления";
                                color: Theme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            Text {
                                text: "проверка новых версий vimit";
                                color: Theme.text-muted;
                                font-size: 11px;
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;

                            Button {
                                text: "Проверить сейчас";
                                clicked => {
                                    root.check-updates();
                                }
                            }

                            Button {
                                text: root.auto-update-check ? "✓ Авто-проверка: ВКЛ" : "✗ Авто-проверка: ВЫКЛ";
                                clicked => {
                                    root.auto-update-check = !root.auto-update-check;
                                    root.auto-update-changed(root.auto-update-check);
                                }
            }
        }

    }
}
            }

            GridLayout {
                spacing: 14px;

                LimitCard {
                    row: 0;
                    col: 0;
                    name: "5h";
                    level: root.five-level;
                    reset: root.five-reset;
                    credits: root.five-credits;
                    requests: root.five-requests;
                    rate: root.five-rate;
                    percent-text: root.five-percent-text;
                    percent: root.five-percent;
                    credit-percent: root.five-credit-percent;
                    request-percent: root.five-request-percent;
                    trend-data: root.five-trend-data;
                    stealth-mode: root.stealth-mode;
                    dimmed: root.period-mode == 2 || (root.risk-only && root.five-percent < 75);
                }

                LimitCard {
                    row: 0;
                    col: 1;
                    name: "24h";
                    level: root.day-level;
                    reset: root.day-reset;
                    credits: root.day-credits;
                    requests: root.day-requests;
                    rate: root.day-rate;
                    percent-text: root.day-percent-text;
                    percent: root.day-percent;
                    credit-percent: root.day-credit-percent;
                    request-percent: root.day-request-percent;
                    trend-data: root.day-trend-data;
                    stealth-mode: root.stealth-mode;
                    dimmed: root.period-mode == 2 || (root.risk-only && root.day-percent < 75);
                }

                LimitCard {
                    row: 1;
                    col: 0;
                    name: "7d";
                    level: root.week-level;
                    reset: root.week-reset;
                    credits: root.week-credits;
                    requests: root.week-requests;
                    rate: root.week-rate;
                    percent-text: root.week-percent-text;
                    percent: root.week-percent;
                    credit-percent: root.week-credit-percent;
                    request-percent: root.week-request-percent;
                    trend-data: root.week-trend-data;
                    stealth-mode: root.stealth-mode;
                    dimmed: root.period-mode == 1 || (root.risk-only && root.week-percent < 75);
                }

                LimitCard {
                    row: 1;
                    col: 1;
                    name: "30d";
                    level: root.month-level;
                    reset: root.month-reset;
                    credits: root.month-credits;
                    requests: root.month-requests;
                    rate: root.month-rate;
                    percent-text: root.month-percent-text;
                    percent: root.month-percent;
                    credit-percent: root.month-credit-percent;
                    request-percent: root.month-request-percent;
                    trend-data: root.month-trend-data;
                    stealth-mode: root.stealth-mode;
                    dimmed: root.period-mode == 1 || (root.risk-only && root.month-percent < 75);
                }
            }
        }
    }

    if (!root.is-overlay && root.needs-setup) : Rectangle {
        background: Theme.bg-primary;

        VerticalLayout {
            padding: 40px;
            spacing: 24px;
            alignment: center;

            Text {
                text: "Добро пожаловать в VibeMode Control";
                color: Theme.text-primary;
                font-size: 32px;
                font-weight: 800;
                horizontal-alignment: center;
            }

            Text {
                text: "Для начала работы необходимо настроить конфигурацию или запустить демо-режим.";
                color: Theme.text-muted;
                font-size: 16px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 20px;
                alignment: center;
                padding-top: 20px;

                Button {
                    text: "Открыть папку с настройками";
                    clicked => { root.open-config-dir(); }
                }

                Button {
                    text: "Запустить в Демо режиме";
                    clicked => {
                        root.needs-setup = false;
                        root.demo-requested();
                    }
                }

                Button {
                    text: "Проверить подключение";
                    clicked => { root.refresh-requested(); }
                }
            }
        }
    }

    if (root.is-overlay && !root.is-compact) : Rectangle {
        background: #0d1117;
        border-color: #30363d;
        border-width: 1px;
        border-radius: 12px;
        padding: 12px;
        
        VerticalLayout {
            padding: 12px;
            spacing: 12px;
            
            // Header
            HorizontalLayout {
                Text {
                    text: "vimit · VibeMode";
                    font-size: 11px;
                    color: #7d8590;
                    vertical-alignment: center;
                }
                Rectangle {}
                HorizontalLayout {
                    spacing: 8px;
                    Button {
                        text: "-";
                        width: 24px;
                        height: 24px;
                        clicked => { root.is-compact = true; }
                    }
                    Button {
                        text: "x";
                        width: 24px;
                        height: 24px;
                        clicked => { root.close-overlay(); }
                    }
                }
            }
            
            // Rate row
            HorizontalLayout {
                Text {
                    text: root.stealth-mode ? "***" : "\{round(root.token-rate-raw)}";
                    font-size: 28px;
                    color: #e6edf3;
                    font-weight: 700;
                }
                Text {
                    text: " " + root.token-rate-text;
                    font-size: 12px;
                    color: #7d8590;
                    vertical-alignment: bottom;
                    padding-bottom: 4px;
                }
                Rectangle {}
            }
            
            // Windows
            VerticalLayout {
                spacing: 6px;
                HorizontalLayout {
                    Text { text: "5h"; width: 28px; font-size: 11px; color: #7d8590; vertical-alignment: center; }
                    Rectangle { height: 6px; border-radius: 3px; background: #21262d; 
                        Rectangle { x: 0; width: parent.width * (root.five-percent / 100); background: root.five-percent >= 90 ? #f85149 : root.five-percent >= 75 ? #d29922 : #3fb950; border-radius: 3px; }
                    }
                    Text { text: root.stealth-mode ? "***" : "\{round(root.five-percent)}%"; width: 44px; horizontal-alignment: right; font-size: 11px; color: root.five-percent >= 90 ? #f85149 : root.five-percent >= 75 ? #d29922 : #3fb950; vertical-alignment: center; }
                }
                HorizontalLayout {
                    Text { text: "24h"; width: 28px; font-size: 11px; color: #7d8590; vertical-alignment: center; }
                    Rectangle { height: 6px; border-radius: 3px; background: #21262d; 
                        Rectangle { x: 0; width: parent.width * (root.day-percent / 100); background: root.day-percent >= 90 ? #f85149 : root.day-percent >= 75 ? #d29922 : #3fb950; border-radius: 3px; }
                    }
                    Text { text: root.stealth-mode ? "***" : "\{round(root.day-percent)}%"; width: 44px; horizontal-alignment: right; font-size: 11px; color: root.day-percent >= 90 ? #f85149 : root.day-percent >= 75 ? #d29922 : #3fb950; vertical-alignment: center; }
                }
                HorizontalLayout {
                    Text { text: "7d"; width: 28px; font-size: 11px; color: #7d8590; vertical-alignment: center; }
                    Rectangle { height: 6px; border-radius: 3px; background: #21262d; 
                        Rectangle { x: 0; width: parent.width * (root.week-percent / 100); background: root.week-percent >= 90 ? #f85149 : root.week-percent >= 75 ? #d29922 : #3fb950; border-radius: 3px; }
                    }
                    Text { text: root.stealth-mode ? "***" : "\{round(root.week-percent)}%"; width: 44px; horizontal-alignment: right; font-size: 11px; color: root.week-percent >= 90 ? #f85149 : root.week-percent >= 75 ? #d29922 : #3fb950; vertical-alignment: center; }
                }
                HorizontalLayout {
                    Text { text: "30d"; width: 28px; font-size: 11px; color: #7d8590; vertical-alignment: center; }
                    Rectangle { height: 6px; border-radius: 3px; background: #21262d; 
                        Rectangle { x: 0; width: parent.width * (root.month-percent / 100); background: root.month-percent >= 90 ? #f85149 : root.month-percent >= 75 ? #d29922 : #3fb950; border-radius: 3px; }
                    }
                    Text { text: root.stealth-mode ? "***" : "\{round(root.month-percent)}%"; width: 44px; horizontal-alignment: right; font-size: 11px; color: root.month-percent >= 90 ? #f85149 : root.month-percent >= 75 ? #d29922 : #3fb950; vertical-alignment: center; }
                }
            }
            
            Rectangle { height: 1px; background: #21262d; }
            
            // Sparkline
            VerticalLayout {
                spacing: 4px;
                Text { text: "расход за 15 мин"; font-size: 10px; color: #484f58; }
                HorizontalLayout {
                    height: 36px;
                    spacing: 2px;
                    alignment: start;
                    for val in root.five-trend-data : Rectangle {
                        width: 14px;
                        height: max(2px, parent.height * val / 100);
                        y: parent.height - self.height;
                        background: val >= 90 ? #f85149 : val >= 75 ? #d29922 : #3fb950;
                        border-radius: 2px;
                        opacity: 0.8;
                    }
                }
            }
            
            HorizontalLayout {
                Text { text: "сброс 5h окна"; font-size: 11px; color: #7d8590; }
                Rectangle {}
                Rectangle {
                    background: #1f2937;
                    border-radius: 10px;
                    padding-left: 8px; padding-right: 8px;
                    Text { text: root.five-reset; font-size: 11px; color: #2a78d6; }
                }
            }
        }
    }
    
    if (root.is-overlay && root.is-compact) : Rectangle {
        background: #0d1117;
        border-color: #30363d;
        border-width: 1px;
        border-radius: 8px;
        
        HorizontalLayout {
            padding: 10px;
            spacing: 10px;
            Rectangle {
                width: 8px; height: 8px; border-radius: 4px;
                background: root.five-percent >= 90 ? #f85149 : root.five-percent >= 75 ? #d29922 : #3fb950;
                y: 8px;
            }
            VerticalLayout {
                Text {
                    text: "5h: " + (root.stealth-mode ? "***" : "\{round(root.five-percent)}%") + " · " + (root.stealth-mode ? "***" : "\{round(root.token-rate-raw)} " + root.token-rate-text);
                    font-size: 12px; color: #e6edf3; font-weight: 700;
                }
                Text {
                    text: "клик для раскрытия";
                    font-size: 10px; color: #7d8590;
                }
            }
        }
        
        TouchArea {
            clicked => { root.is-compact = false; }
        }
    }
}
